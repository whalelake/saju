{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bun run build",
  "devCommand": "bun run dev",
  "outputDirectory": "dist",
  "installCommand": "bun install",
  "framework": "vite",
  "rewrites": [
    { "source": "/ko/:path*", "destination": "/index.html" },
    { "source": "/en/:path*", "destination": "/index.html" },
    { "source": "/ja/:path*", "destination": "/index.html" },
    { "source": "/zh/:path*", "destination": "/index.html" },
    { "source": "/ko", "destination": "/index.html" },
    { "source": "/en", "destination": "/index.html" },
    { "source": "/ja", "destination": "/index.html" },
    { "source": "/zh", "destination": "/index.html" }
  ]
}
