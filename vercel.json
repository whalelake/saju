{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bun run build",
  "devCommand": "bun run dev",
  "outputDirectory": "dist",
  "installCommand": "bun install",
  "framework": "vite",
  "rewrites": [
    { "source": "/(ko|en|ja|zh)/(.*)", "destination": "/index.html" },
    { "source": "/(ko|en|ja|zh)", "destination": "/index.html" }
  ]
}
